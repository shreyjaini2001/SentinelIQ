# Anthropic API
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Set to true to run with no API credits (keyword-based mock responses)
# Set to false to use the real Anthropic API
MOCK_LLM=true

# App config
APP_ENV=development
API_PORT=8000
WEB_PORT=5173

# Session config
SESSION_TTL_HOURS=8
SESSION_DB_PATH=./sentineliq_sessions.db

# LLM models (only used when MOCK_LLM=false)
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
NLQ_MODEL=claude-sonnet-4-6
ACTION_MODEL=claude-sonnet-4-6
