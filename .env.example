# SentinelIQ environment (backend) — copy to .env at the project root.
# The FastAPI backend (apps/api/config.py) reads .env from THIS project root.
# Placeholders only — never commit a real .env or a real key.

# --- AI provider ---
# Get a key at https://console.anthropic.com (only used when MOCK_LLM=false)
ANTHROPIC_API_KEY=your_api_key_here

# Keep true to run with NO API credits (deterministic keyword/intent mocks).
# Set false only to use the real Anthropic API.
MOCK_LLM=true

# --- App config ---
APP_ENV=development
API_PORT=8000
WEB_PORT=5173

# Comma-separated allowed CORS origins for the web frontend.
# For a deployed demo, set this to your frontend URL, e.g.
# CORS_ORIGINS=https://sentineliq.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Session config ---
SESSION_TTL_HOURS=8
SESSION_DB_PATH=./sentineliq_sessions.db

# --- Local demo persistence (v1.2.0) ---
# SQLite file backing investigation memory, alert lifecycle, and workspace checkpoints.
# Local demo only (no auth) — the *.db file is gitignored. Use ":memory:" for ephemeral runs.
SENTINELIQ_DB_PATH=apps/api/data/sentineliq_demo.db

# --- LLM models (only used when MOCK_LLM=false) ---
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
NLQ_MODEL=claude-sonnet-4-6
ACTION_MODEL=claude-sonnet-4-6
