# SentinelIQ backend env reference (apps/api).
#
# NOTE: the backend loads .env from the PROJECT ROOT (see apps/api/config.py),
# so the effective file is ../../.env — copy the project-root .env.example to
# .env at the repo root. These are the variables the backend reads; this file
# is a convenience reference. Placeholders only — never commit real secrets.

ANTHROPIC_API_KEY=your_api_key_here
MOCK_LLM=true

APP_ENV=development
API_PORT=8000

# Comma-separated allowed CORS origins (set to your frontend URL when deployed).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

SESSION_TTL_HOURS=8
SESSION_DB_PATH=./sentineliq_sessions.db

# Local demo persistence (v1.2.0) — SQLite file for investigation memory, alert lifecycle,
# and workspace checkpoints. Local demo only; the *.db file is gitignored.
SENTINELIQ_DB_PATH=apps/api/data/sentineliq_demo.db

CLASSIFIER_MODEL=claude-haiku-4-5-20251001
NLQ_MODEL=claude-sonnet-4-6
ACTION_MODEL=claude-sonnet-4-6
