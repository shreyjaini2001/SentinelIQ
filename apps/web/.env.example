# SentinelIQ frontend env (apps/web) — copy to apps/web/.env.local to override.
# Vite inlines VITE_* variables at BUILD time. Placeholders only.

# Backend origin for a DEPLOYED frontend. Leave UNSET for local dev — the Vite
# dev proxy (vite.config.ts) forwards /api to http://localhost:8000 automatically.
# In production set this to your backend URL; the app appends /api/v1.
# VITE_API_BASE_URL=https://sentineliq-api.onrender.com
